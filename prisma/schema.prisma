
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// souma schema
model Client {
  client_id         Int      @id @default(autoincrement())
  first_name        String
  last_name         String
  user_name         String   @unique
  email             String   @unique
  password          String
  phn_no            String?
  company_name      String?
  profile_image_url String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// deb schema
model Contact {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String?
  designation String?
  country     String?
  image       String?
  rating      Float    @default(0)
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}